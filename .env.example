# Database
DATABASE_URL=postgresql://gms_svn:gms_svn_dev@localhost:5432/gms_svn?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# API
API_HOST=0.0.0.0
API_PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:5175

# GMS SVN SERVER — Server Agent (Phase 3, runs on GMS SVN SERVER)
AGENT_BASE_URL=http://localhost:8443
AGENT_HMAC_SECRET=change-me-agent-hmac-secret-min-32-chars
AGENT_MOCK=true

# GMS SVN SERVER — Network Storage (Phase 2)
STORAGE_REPO_ROOT=\\\\GMS-NAS\\SVN\\Repositories
STORAGE_BACKUP_PATH=\\\\GMS-NAS\\SVN\\Backups
STORAGE_REPORTS_PATH=\\\\GMS-NAS\\SVN\\Reports
STORAGE_ATTACHMENTS_PATH=\\\\GMS-NAS\\SVN\\Attachments
STORAGE_LOGS_PATH=\\\\GMS-NAS\\SVN\\Logs

# GMS SVN SERVER — VisualSVN
GMS_SVN_SERVER_HOST=gms-svn-server.local
VISUALSVN_REPO_ROOT=D:\\SVN\\Repositories
VISUALSVN_URL=https://gms-svn-server.local/svn

# GMS SVN CLIENT (Phase 5)
GMS_SVN_CLIENT_SVN_EXE=C:\\Program Files\\TortoiseSVN\\bin\\svn.exe
CLIENT_SVN_MOCK=true

# Frontend (leave empty in dev — Vite proxy; set for production build)
VITE_API_BASE_URL=

# Phase 9 — Build automation (post-commit → CI webhook)
PIPELINE_HOOK_SECRET=change-me-pipeline-hook-secret
API_PUBLIC_URL=http://localhost:3001
# PIPELINE_HOOK_SCRIPT=D:\\GMS-SVN\\infra\\hooks\\gms-svn-post-commit.ps1
