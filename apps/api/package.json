{
  "name": "@gms-svn/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "node -e \"process.exit(0)\"",
    "test": "node --test --import tsx src/health.test.ts src/services/storage-connection-test.test.ts src/lib/agent-client.test.ts src/services/client-repo-service.test.ts src/services/report-service.test.ts src/services/pipeline-service.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@gms-svn/shared": "*",
    "@gms-svn/svn-contracts": "*",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.41.0",
    "ioredis": "^5.4.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.16.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pdfkit": "^0.13.9",
    "@types/node": "^22.13.10",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
