{
  "name": "@gms-svn/client",
  "version": "0.1.0",
  "private": true,
  "description": "GMS SVN CLIENT — Windows desktop SVN client",
  "author": {
    "name": "GMS"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "npm run build && electron-builder --win",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "node -e \"process.exit(0)\"",
    "test": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@gms-svn/shared": "*",
    "electron-store": "^10.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "34.5.8",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  },
  "build": {
    "electronVersion": "34.5.8",
    "appId": "com.gms.svn.client",
    "productName": "GMS SVN CLIENT",
    "copyright": "Copyright © 2026 GMS",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "GMS-SVN-CLIENT-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GMS SVN CLIENT"
    }
  }
}
